# Copia este archivo a .env y ajusta los valores. NO commitees .env.
PORT=4000

# Base de datos (fase backend-first). En piloto se usa store en memoria.
# DATABASE_URL=postgres://user:pass@localhost:5432/restaurantos

# Secreto para firmar sesiones/JWT
JWT_SECRET=cambia-esto-en-produccion

# Configuración de negocio por defecto (overridable por tenant)
TAX_LABEL=IVA
TAX_RATE=0.085
URGENCY_MINUTES=15
MAX_QTY_PER_LINE=20
