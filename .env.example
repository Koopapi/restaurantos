# ──────────────────────────────────────────────────────────────────────────
# RestaurantOS — variables de entorno (Docker)
#
# Copia este archivo a `.env` y ajusta los valores. Genera secrets con:
#   openssl rand -hex 32
#
# Tip: `scripts/bootstrap.sh` rellena automáticamente los secrets vacíos al
# primer arranque, no tienes que hacerlo a mano.
#
# NUNCA commitees el `.env` real. Si crees que un secret se filtró, rótalo.
# ──────────────────────────────────────────────────────────────────────────

# ─────────── Backend (Node + Express + ws) ───────────
# Puerto publicado en el host (el contenedor siempre escucha en 4000).
BACKEND_PORT=4000

# Secreto para firmar/verificar los JWT. Déjalo vacío y bootstrap.sh lo genera.
JWT_SECRET=

# ─────────── Reglas de negocio por defecto ───────────
# Overridables en caliente por admin vía PUT /api/config.
TAX_LABEL=IVA
TAX_RATE=0.085
URGENCY_MINUTES=15
MAX_QTY_PER_LINE=20
